# Copy this file to `.env` (no extension) and fill in your bot token.
# Then start the bot with:  npm run start:env
#
# Get the token from https://discord.com/developers/applications
#   → your app → Bot → Reset Token

DISCORD_TOKEN=paste_your_bot_token_here

# Optional — only set if Ollama is not on localhost:
# OLLAMA_URL=http://localhost:11434
